{
  "name": "daity",
  "version": "1.0.0",
  "description": "桌面待办事项应用 - 支持每日任务自动重置",
  "main": "main.js",
  "scripts": {
    "start": "electron --disable-gpu --disable-gpu-sandbox .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": ["todo", "daily", "electron"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.daity.app",
    "productName": "Daity",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Daity",
      "language": "2052"
    },
    "extraResources": []
  }
}
